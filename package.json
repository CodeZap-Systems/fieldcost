{
  "name": "fieldcost",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "npm run test:api && npm run test:e2e",
    "test:api": "vitest run --reporter=verbose",
    "test:e2e": "playwright test",
    "test:seed": "node scripts/test-seed.mjs",
    "test:seed:clear": "node scripts/test-seed.mjs --clear",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --no-coverage",
    "test:auth": "vitest run tests/api/auth.test.ts --reporter=verbose",
    "test:projects": "vitest run tests/api/projects.test.ts --reporter=verbose",
    "test:invoices": "vitest run tests/api/invoices.test.ts --reporter=verbose",
    "test:tasks": "vitest run tests/api/tasks.test.ts --reporter=verbose",
    "test:inventory": "vitest run tests/api/inventory.test.ts --reporter=verbose",
    "test:company": "vitest run tests/api/company.test.ts --reporter=verbose",
    "test:admin": "vitest run tests/api/admin.test.ts --reporter=verbose",
    "test:security": "jest --config jest.security.config.js --testPathPattern=security --runInBand",
    "test:security:watch": "jest --config jest.security.config.js --testPathPattern=security --watch",
    "test:security:coverage": "jest --config jest.security.config.js --testPathPattern=security --coverage",
    "test:security:auth": "jest tests/security/auth-security.test.ts --config jest.security.config.js",
    "test:security:api": "jest tests/security/api-security.test.ts --config jest.security.config.js",
    "test:security:upload": "jest tests/security/upload-security.test.ts --config jest.security.config.js",
    "test:security:rbac": "jest tests/security/rbac-security.test.ts --config jest.security.config.js",
    "test:all": "npm run test:api && npm run test:e2e && npm run test:security",
    "demo:seed": "node scripts/demo-seed.mjs",
    "db:fix-company-ids": "node scripts/fix-company-ids.mjs"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@supabase/supabase-js": "^2.98.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.19.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "@types/react": "^18.3.1",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.0.0",
    "eslint": "^9.14.0",
    "eslint-config-next": "^16.1.6",
    "node-fetch": "^3.3.2",
    "postcss": "^8.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.0.0",
    "vitest": "^4.0.18"
  }
}
